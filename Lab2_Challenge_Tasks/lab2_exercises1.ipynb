   "source": [
    "target_name = \"BEJAR\"\n",
    "SEED_NUM = 7\n",
    "redacted_name = \"\"\n",
    "\n",
    "for char in target_name:\n",
    "    if char in \"AEIOU\":\n",
    "        redacted_name += str(SEED_NUM)\n",
    "    else:\n",
    "        redacted_name += char\n",
    "\n",
    "print(f\"Original:\", target_name)\n",
    "print(f\"Redacted:\", redacted_name)"
   ]
  }
